# =============================================
# JJ Desserts - Environment variables
# Copy this file to `.env` and fill in real values
# =============================================

# Sanity CMS (get these from sanity.io after creating a project)
PUBLIC_SANITY_PROJECT_ID=your-project-id-here
PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-write-token-here

# Stripe (get these from dashboard.stripe.com)
# Use TEST keys (pk_test_..., sk_test_...) during development
# Switch to LIVE keys (pk_live_..., sk_live_...) only when ready to launch
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Site config
PUBLIC_SITE_URL=http://localhost:4321
SALES_TAX_RATE=0.0825
