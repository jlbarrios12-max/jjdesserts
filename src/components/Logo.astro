---
interface Props {
  size?: 'normal' | 'small';
  variant?: 'light' | 'dark';
}
const { size = 'normal', variant = 'light' } = Astro.props;

// Same transparent PNG used everywhere.
// "light" = used on light surfaces (header) — logo stays its natural color (black on transparent)
// "dark"  = used on dark surfaces (footer) — CSS filter inverts black to white
---

<img
  src="/images/jj-logo.png"
  alt="JJ Desserts — Different Not Less"
  class={`logo-image ${size === 'small' ? 'small' : ''} ${variant}`}
  width={size === 'small' ? 100 : 120}
  height={size === 'small' ? 94 : 112}
  loading="eager"
  decoding="async"
/>
