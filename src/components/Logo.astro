---
interface Props {
  size?: 'normal' | 'small';
}
const { size = 'normal' } = Astro.props;
---

<img
  src="/images/jj-logo.jpg"
  alt="JJ Desserts — Different Not Less"
  class={`logo-image ${size === 'small' ? 'small' : ''}`}
  width={size === 'small' ? 95 : 110}
  height={size === 'small' ? 95 : 110}
  loading="eager"
  decoding="async"
/>
