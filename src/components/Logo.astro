---
interface Props {
  size?: 'normal' | 'small';
  variant?: 'light' | 'dark';
}
const { size = 'normal', variant = 'light' } = Astro.props;

// light = white background with black logo (use on light surfaces, e.g. header)
// dark  = black background with white logo (use on dark surfaces, e.g. footer)
const src = variant === 'light' ? '/images/jj-logo-light.jpg' : '/images/jj-logo.jpg';
---

<img
  src={src}
  alt="JJ Desserts — Different Not Less"
  class={`logo-image ${size === 'small' ? 'small' : ''} ${variant}`}
  width={size === 'small' ? 95 : 110}
  height={size === 'small' ? 95 : 110}
  loading="eager"
  decoding="async"
/>
