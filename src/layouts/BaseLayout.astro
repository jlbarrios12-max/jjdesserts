---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../sanity/queries';
import type { SiteSettings } from '../sanity/types';
import type { Locale } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
}
const { title, description, locale } = Astro.props;

let settings: SiteSettings | null = null;
try {
  settings = await getSiteSettings();
} catch (e) {
  console.warn('Sanity not configured yet — using defaults for site settings.');
}

const announcement = locale === 'es'
  ? (settings?.announcementEs ?? 'SABOR QUE ENAMORA')
  : (settings?.announcementEn ?? 'A TASTE THAT ENCHANTS');
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description ?? 'JJ Desserts - Postres caseros'} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Dancing+Script:wght@600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <TopBar announcement={announcement} />
  <Header locale={locale} />

  <slot name="hero-settings" />
  <slot />

  <Footer locale={locale} settings={settings} />
</body>
</html>
