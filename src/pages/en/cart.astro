---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStrings } from '../../i18n/strings';

export const prerender = true;

const locale = 'en';
const t = getStrings(locale);
---

<BaseLayout title="Your Cart | JJ Desserts" description="Review your order and place it" locale={locale}>
  <section class="cart-section">

    <!-- Empty state -->
    <div class="cart-empty" id="cartEmpty" style="display:none;">
      <div class="cart-empty-icon">🛒</div>
      <h2>{t.cart.empty}</h2>
      <p>Add some desserts from our <a href="/en/menu">menu</a>.</p>
    </div>

    <!-- Cart content -->
    <div class="cart-content" id="cartContent" style="display:none;">
      <h2 class="cart-title">{t.cart.title}</h2>

      <div class="cart-layout">
        <div class="cart-items-col">
          <div id="cartItemsList"></div>
        </div>

        <aside class="cart-sidebar">
          <!-- Order summary -->
          <div class="cart-summary">
            <h3 class="cart-summary-title">Order Summary</h3>
            <div class="cart-summary-row">
              <span>{t.cart.subtotal}</span>
              <span id="summarySubtotal">$0.00</span>
            </div>
            <div class="cart-summary-row">
              <span>{t.cart.tax} (7%)</span>
              <span id="summaryTax">$0.00</span>
            </div>
            <div class="cart-summary-row cart-summary-total">
              <span>{t.cart.total}</span>
              <span id="summaryTotal">$0.00</span>
            </div>
          </div>

          <!-- Customer form -->
          <form
            id="orderForm"
            name="order"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <input type="hidden" name="form-name" value="order" />
            <input type="hidden" name="pedido" id="fieldPedido" />
            <input type="hidden" name="total" id="fieldTotal" />
            <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <h3 class="cart-form-title">Your Information</h3>

            <div class="cart-form-group">
              <label for="nombre">Full name *</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Your name" />
            </div>

            <div class="cart-form-group">
              <label for="email">Email address *</label>
              <input type="email" id="email" name="email" required placeholder="you@email.com" />
            </div>

            <div class="cart-form-group">
              <label for="telefono">Phone number *</label>
              <input type="tel" id="telefono" name="telefono" required placeholder="(555) 000-0000" />
            </div>

            <div class="cart-form-group">
              <label>Delivery type *</label>
              <div class="cart-radio-group">
                <label class="cart-radio-label">
                  <input type="radio" name="tipo-entrega" value="Pickup" required />
                  <span>Pickup</span>
                </label>
                <label class="cart-radio-label">
                  <input type="radio" name="tipo-entrega" value="Delivery" />
                  <span>Delivery</span>
                </label>
              </div>
            </div>

            <div class="cart-form-group">
              <label for="fecha">Preferred date</label>
              <input type="date" id="fecha" name="fecha-preferida" />
            </div>

            <div class="cart-form-group">
              <label for="notas">Additional notes</label>
              <textarea id="notas" name="notas" rows="3" placeholder="Allergies, dedications, special instructions..."></textarea>
            </div>

            <button type="submit" class="cart-submit-btn" id="submitBtn">
              Place Order
            </button>
          </form>
        </aside>
      </div>
    </div>

    <!-- Success message -->
    <div class="cart-success" id="cartSuccess" style="display:none;">
      <div class="cart-success-icon">✓</div>
      <h2>Order Sent!</h2>
      <p id="successMsg"></p>
      <p class="cart-success-sub">JJ Desserts will get in touch with you to coordinate pickup and payment.</p>
      <a href="/en/menu" class="btn btn-primary" style="margin-top:24px; display:inline-block;">Browse more desserts</a>
    </div>

  </section>
</BaseLayout>

<script>
  const TAX_RATE = 0.07;

  type CartItem = {
    dessertId: string;
    nameEs: string;
    nameEn: string;
    price: number;
    quantity: number;
    imageUrl: string;
    slug: string;
    sizeEs?: string;
    sizeEn?: string;
  };

  function getCart(): CartItem[] {
    try { return JSON.parse(localStorage.getItem('jj_cart') || '[]'); }
    catch { return []; }
  }

  function saveCart(cart: CartItem[]) {
    localStorage.setItem('jj_cart', JSON.stringify(cart));
    document.dispatchEvent(new Event('cart:updated'));
  }

  function fmt(n: number) { return '$' + n.toFixed(2); }

  function buildPedidoText(cart: CartItem[]): string {
    let lines = cart.map(item => {
      const size = item.sizeEn ? ` (${item.sizeEn})` : '';
      const lineTotal = item.price * item.quantity;
      return `${item.quantity}x ${item.nameEn}${size} - ${fmt(item.price)} ea = ${fmt(lineTotal)}`;
    });
    const subtotal = cart.reduce((s, i) => s + i.price * i.quantity, 0);
    const tax = subtotal * TAX_RATE;
    const total = subtotal + tax;
    lines.push('---');
    lines.push(`Subtotal: ${fmt(subtotal)}`);
    lines.push(`Tax (7%): ${fmt(tax)}`);
    lines.push(`TOTAL: ${fmt(total)}`);
    return lines.join('\n');
  }

  function renderCart() {
    const cart = getCart();
    const emptyEl  = document.getElementById('cartEmpty')!;
    const contentEl = document.getElementById('cartContent')!;

    if (cart.length === 0) {
      emptyEl.style.display = '';
      contentEl.style.display = 'none';
      return;
    }

    emptyEl.style.display = 'none';
    contentEl.style.display = '';

    const listEl = document.getElementById('cartItemsList')!;
    listEl.innerHTML = cart.map((item, idx) => {
      const size = item.sizeEn ? `<span class="cart-item-size">${item.sizeEn}</span>` : '';
      return `
        <div class="cart-item" data-idx="${idx}">
          <img src="${item.imageUrl}" alt="${item.nameEn}" class="cart-item-img" />
          <div class="cart-item-info">
            <p class="cart-item-name">${item.nameEn}</p>
            ${size}
            <p class="cart-item-unit">${fmt(item.price)} ea</p>
          </div>
          <div class="cart-item-controls">
            <button class="qty-btn" data-action="dec" data-idx="${idx}">−</button>
            <span class="qty-val">${item.quantity}</span>
            <button class="qty-btn" data-action="inc" data-idx="${idx}">+</button>
          </div>
          <div class="cart-item-total">${fmt(item.price * item.quantity)}</div>
          <button class="cart-item-remove" data-action="remove" data-idx="${idx}" title="Remove">✕</button>
        </div>
      `;
    }).join('');

    const subtotal = cart.reduce((s, i) => s + i.price * i.quantity, 0);
    const tax = subtotal * TAX_RATE;
    const total = subtotal + tax;
    document.getElementById('summarySubtotal')!.textContent = fmt(subtotal);
    document.getElementById('summaryTax')!.textContent = fmt(tax);
    document.getElementById('summaryTotal')!.textContent = fmt(total);

    (document.getElementById('fieldPedido') as HTMLInputElement).value = buildPedidoText(cart);
    (document.getElementById('fieldTotal') as HTMLInputElement).value = fmt(total);

    listEl.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.idx || '0');
        const cart2 = getCart();
        const action = btn.dataset.action;
        if (action === 'inc') {
          cart2[idx].quantity += 1;
          saveCart(cart2);
        } else if (action === 'dec') {
          cart2[idx].quantity -= 1;
          if (cart2[idx].quantity <= 0) cart2.splice(idx, 1);
          saveCart(cart2);
        } else if (action === 'remove') {
          cart2.splice(idx, 1);
          saveCart(cart2);
        }
        renderCart();
      });
    });
  }

  const form = document.getElementById('orderForm') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const cart = getCart();
    (document.getElementById('fieldPedido') as HTMLInputElement).value = buildPedidoText(cart);
    const subtotal = cart.reduce((s, i) => s + i.price * i.quantity, 0);
    const total = subtotal + subtotal * TAX_RATE;
    (document.getElementById('fieldTotal') as HTMLInputElement).value = fmt(total);

    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const data = new FormData(form);
    const encoded = new URLSearchParams(data as unknown as Record<string, string>).toString();

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: encoded,
      });

      if (res.ok) {
        const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
        localStorage.removeItem('jj_cart');
        document.dispatchEvent(new Event('cart:updated'));
        document.getElementById('cartContent')!.style.display = 'none';
        const successEl = document.getElementById('cartSuccess')!;
        successEl.style.display = '';
        document.getElementById('successMsg')!.textContent =
          `Thank you ${nombre}. Your order has been received.`;
        successEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Place Order';
        alert('There was an error submitting your order. Please try again.');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Place Order';
      alert('Connection error. Please try again.');
    }
  });

  renderCart();
  document.addEventListener('cart:updated', renderCart);
</script>
