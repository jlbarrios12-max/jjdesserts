---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllDesserts, getAllCategories } from '../../../sanity/queries';
import { urlFor } from '../../../sanity/client';
import { getStrings } from '../../../i18n/strings';
import type { Dessert, Category, AllergenKey } from '../../../sanity/types';

const locale = 'en';
const t = getStrings(locale);

let desserts: Dessert[] = [];
let categories: Category[] = [];
try {
  [desserts, categories] = await Promise.all([
    getAllDesserts(),
    getAllCategories(),
  ]);
} catch (e) {
  console.warn('Sanity not configured — menu page running empty.');
}

function displayPrice(d: Dessert): number {
  return d.sizes && d.sizes.length > 0 ? d.sizes[0].price : d.price;
}
---

<BaseLayout title="Menu | JJ Desserts" description="Our handmade dessert catalog" locale={locale}>
  <section class="menu-section">
    <div class="menu-header">
      <h2>{t.menu.title}</h2>
      <p>{t.menu.subtitle}</p>
    </div>

    {categories.length > 0 && (
      <div class="category-filters" id="categoryFilters">
        <button class="active" data-category="all">{t.menu.filterAll}</button>
        {categories.map((c) => (
          <button data-category={c.slug}>{c.nameEn}</button>
        ))}
      </div>
    )}

    {desserts.length > 0 ? (
      <div id="dessertGrid">
        {categories.map((cat) => {
          const inCat = desserts.filter((d) => d.category?.slug === cat.slug);
          if (inCat.length === 0) return null;
          return (
            <section class="menu-category-section" data-category={cat.slug}>
              <h3 class="menu-category-header">{cat.nameEn}</h3>
              <div class="dessert-grid">
                {inCat.map((d) => (
                  <article class="dessert-card" data-category={d.category?.slug}>
                    <a href={`/en/menu/${d.slug}`} class="dessert-card-image">
                      <img src={urlFor(d.mainImage).width(600).url()} alt={d.nameEn} loading="lazy" />
                    </a>
                    <div class="dessert-card-body">
                      <span class="dessert-card-category">{d.category?.nameEn}</span>
                      <h3 class="dessert-card-name">
                        <a href={`/en/menu/${d.slug}`}>{d.nameEn}</a>
                      </h3>
                      {d.descriptionEn && <p class="dessert-card-desc">{d.descriptionEn}</p>}

                      {d.allergens && d.allergens.length > 0 && (
                        <div class="allergens">
                          <span class="allergens-label">{t.menu.allergensLabel}:</span>
                          {d.allergens.map((a: AllergenKey) => (
                            <span class="allergen-tag">{t.allergens[a]}</span>
                          ))}
                        </div>
                      )}

                      {d.sizes && d.sizes.length > 0 && (
                        <div class="size-selector">
                          {d.sizes.map((s, i) => (
                            <button
                              class={`size-btn${i === 0 ? ' active' : ''}`}
                              data-price={s.price}
                              data-label-es={s.labelEs}
                              data-label-en={s.labelEn}
                            >
                              <span class="size-label">{s.labelEn}</span>
                              <span class="size-price">{'$'}{s.price.toFixed(2)}</span>
                            </button>
                          ))}
                        </div>
                      )}

                      <div class="dessert-card-footer">
                        <span class="dessert-card-price">{'$'}{displayPrice(d).toFixed(2)}</span>
                        <button
                          class="dessert-card-add"
                          data-add-to-cart
                          data-id={d._id}
                          data-name-es={d.nameEs}
                          data-name-en={d.nameEn}
                          data-price={displayPrice(d)}
                          data-image={urlFor(d.mainImage).width(400).url()}
                          data-slug={d.slug}
                          data-size-es={d.sizes && d.sizes.length > 0 ? d.sizes[0].labelEs : ''}
                          data-size-en={d.sizes && d.sizes.length > 0 ? d.sizes[0].labelEn : ''}
                        >{t.menu.addToCart}</button>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    ) : (
      <p style="text-align:center; color: var(--gray); padding: 40px;">
        We're preparing our menu. Check back soon.
      </p>
    )}
  </section>
</BaseLayout>

<script>
  // Category filter
  const filters = document.querySelectorAll('#categoryFilters button');
  const sections = document.querySelectorAll<HTMLElement>('#dessertGrid .menu-category-section');
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');
      filters.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      sections.forEach((s) => {
        const sCat = s.getAttribute('data-category');
        const show = cat === 'all' || sCat === cat;
        s.style.display = show ? '' : 'none';
        const header = s.querySelector<HTMLElement>('.menu-category-header');
        if (header) header.style.display = cat === 'all' ? '' : 'none';
      });
    });
  });

  // Size selector
  document.querySelectorAll('.size-btn').forEach((sBtn) => {
    sBtn.addEventListener('click', () => {
      const card = sBtn.closest('.dessert-card');
      if (!card) return;
      card.querySelectorAll('.size-btn').forEach((b) => b.classList.remove('active'));
      sBtn.classList.add('active');
      const addBtn = card.querySelector('[data-add-to-cart]');
      if (addBtn) {
        (addBtn as HTMLButtonElement).dataset.price = (sBtn as HTMLElement).dataset.price || '';
        (addBtn as HTMLButtonElement).dataset.sizeEs = (sBtn as HTMLElement).dataset.sizeEs || '';
        (addBtn as HTMLButtonElement).dataset.sizeEn = (sBtn as HTMLElement).dataset.sizeEn || '';
        const priceEl = card.querySelector('.dessert-card-price');
        if (priceEl) {
          const p = parseFloat((sBtn as HTMLElement).dataset.price || '0');
          priceEl.textContent = '$' + p.toFixed(2);
        }
      }
    });
  });

  // Add to cart
  type CartItem = { dessertId: string; nameEs: string; nameEn: string; price: number; quantity: number; imageUrl: string; slug: string; sizeEs?: string; sizeEn?: string; };
  document.querySelectorAll<HTMLButtonElement>('[data-add-to-cart]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cart: CartItem[] = JSON.parse(localStorage.getItem('jj_cart') || '[]');
      const id = btn.dataset.id || '';
      const sizeEs = btn.dataset.sizeEs || '';
      const existing = cart.find((i) => i.dessertId === id && (i.sizeEs || '') === sizeEs);
      if (existing) { existing.quantity += 1; }
      else {
        cart.push({ dessertId: id, nameEs: btn.dataset.nameEs || '', nameEn: btn.dataset.nameEn || '',
          price: parseFloat(btn.dataset.price || '0'), quantity: 1,
          imageUrl: btn.dataset.image || '', slug: btn.dataset.slug || '', sizeEs, sizeEn: btn.dataset.sizeEn || '' });
      }
      localStorage.setItem('jj_cart', JSON.stringify(cart));
      document.dispatchEvent(new Event('cart:updated'));
      btn.textContent = 'OK';
      setTimeout(() => { btn.textContent = 'Agregar'; }, 1200);
    });
  });
</script>
