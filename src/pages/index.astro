---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getSiteSettings, getFeaturedDesserts } from '../sanity/queries';
import { urlFor } from '../sanity/client';
import { getStrings } from '../i18n/strings';
import type { SiteSettings, Dessert } from '../sanity/types';

const locale = 'es';
const t = getStrings(locale);
const menuPath = '/menu';

let settings: SiteSettings | null = null;
let featured: Dessert[] = [];
try {
  [settings, featured] = await Promise.all([
    getSiteSettings(),
    getFeaturedDesserts(),
  ]);
} catch (e) {
  console.warn('Sanity not configured — landing page running with empty data.');
}

const PUZZLE_PATH = "M15 2h10v5.5c0 .6.3 1.1.8 1.4.5.3 1.1.3 1.6 0 .8-.5 1.8-.3 2.4.4l3.4 3.4c.7.7.9 1.6.4 2.4-.3.5-.3 1.1 0 1.6.3.5.8.8 1.4.8H38v10h-5.5c-.6 0-1.1.3-1.4.8-.3.5-.3 1.1 0 1.6.5.8.3 1.8-.4 2.4l-3.4 3.4c-.7.7-1.6.9-2.4.4-.5-.3-1.1-.3-1.6 0-.5.3-.8.8-.8 1.4V38H15v-5.5c0-.6-.3-1.1-.8-1.4-.5-.3-1.1-.3-1.6 0-.8.5-1.8.3-2.4-.4L6.8 27.3c-.7-.7-.9-1.6-.4-2.4.3-.5.3-1.1 0-1.6-.3-.5-.8-.8-1.4-.8H2V12h5.5c.6 0 1.1-.3 1.4-.8.3-.5.3-1.1 0-1.6-.5-.8-.3-1.8.4-2.4l3.4-3.4c.7-.7 1.6-.9 2.4-.4.5.3 1.1.3 1.6 0 .5-.3.8-.8.8-1.4V2z";
---

<BaseLayout title="JJ Desserts - Sabor que enamora" description="Postres caseros hechos con amor. Sabor que enamora." locale={locale}>
  <Hero locale={locale} settings={settings} />

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="cta-container">
      <div class="cta-image">
        {featured.length > 0
          ? <img src={urlFor(featured[0].mainImage).width(400).url()} alt={featured[0].nameEs} />
          : <img src="https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=400&q=80" alt="Cheesecake JJ Desserts" />
        }
        {featured.length > 1
          ? <img src={urlFor(featured[1].mainImage).width(400).url()} alt={featured[1].nameEs} class="overlap" />
          : <img src="https://images.unsplash.com/photo-1596566996073-db2e9a8f7ac6?w=400&q=80" alt="Cheesecake JJ Desserts" class="overlap" />
        }
        {featured.length > 2
          ? <img src={urlFor(featured[2].mainImage).width(400).url()} alt={featured[2].nameEs} class="overlap-2" />
          : <img src="https://images.unsplash.com/photo-1488477181946-6428a0291777?w=400&q=80" alt="Postre JJ Desserts" class="overlap-2" />
        }
      </div>
      <div class="cta-content">
        <div class="cta-decoration">
          <svg viewBox="0 0 40 40" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="autism awareness">
            <path d={PUZZLE_PATH} />
          </svg>
        </div>
        <h2 class="cta-title">{t.cta.title}</h2>
        <p class="cta-subtitle">{t.cta.subtitle}</p>
        <a href={menuPath} class="btn btn-outline">{t.cta.btn}</a>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="values">
    <div class="values-container">
      <div class="value-card">
        <div class="value-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22V12M12 12C12 12 9 9 9 7s3-5 3-5M12 12c0 0 3-3 3-5s-3-5-3-5M5 17c0 0 3-2 7-2s7 2 7 2"/>
          </svg>
        </div>
        <div>
          <p class="value-title">{t.values.quality.line1}<br /><strong>{t.values.quality.line2}</strong></p>
          <p class="value-text">{t.values.quality.text}</p>
        </div>
      </div>
      <div class="value-card">
        <div class="value-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <div>
          <p class="value-title">{t.values.passion.line1}<br /><strong>{t.values.passion.line2}</strong></p>
          <p class="value-text">{t.values.passion.text}</p>
        </div>
      </div>
      <div class="value-card">
        <div class="value-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="8" width="18" height="14" rx="2"/>
            <path d="M12 8V22M3 13h18"/>
            <path d="M8 8C8 5 9.5 3 12 3s4 2 4 5"/>
          </svg>
        </div>
        <div>
          <p class="value-title">{t.values.occasion.line1}<br /><strong>{t.values.occasion.line2}</strong></p>
          <p class="value-text">{t.values.occasion.text}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured desserts -->
  {featured.length > 0 && (
    <section class="menu-section">
      <div class="menu-header">
        <h2>Destacados</h2>
        <p>Nuestros postres mas pedidos</p>
      </div>
      <div class="dessert-grid">
        {featured.map((d) => (
          <article class="dessert-card" data-category={d.category?.nameEs}>
            <a href={`/menu/${d.slug}`} class="dessert-card-image">
              <img src={urlFor(d.mainImage).width(600).url()} alt={d.nameEs} loading="lazy" />
            </a>
            <div class="dessert-card-body">
              <span class="dessert-card-category">{d.category?.nameEs}</span>
              <h3 class="dessert-card-name">
                <a href={`/menu/${d.slug}`}>{d.nameEs}</a>
              </h3>
              <div class="dessert-card-footer">
                <span class="dessert-card-price">${(d.sizes && d.sizes.length > 0 ? d.sizes[0].price : d.price).toFixed(2)}</span>
                <button
                  class="dessert-card-add"
                  data-add-to-cart
                  data-id={d._id}
                  data-name-es={d.nameEs}
                  data-name-en={d.nameEn}
                  data-price={d.sizes && d.sizes.length > 0 ? d.sizes[0].price : d.price}
                  data-image={urlFor(d.mainImage).width(400).url()}
                  data-slug={d.slug}
                  data-size-es={d.sizes && d.sizes.length > 0 ? d.sizes[0].labelEs : ''}
                  data-size-en={d.sizes && d.sizes.length > 0 ? d.sizes[0].labelEn : ''}
                >{t.menu.addToCart}</button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter hidden until backend is ready -->
  <section class="newsletter" style="display:none">
    <div class="newsletter-container">
      <div>
        <div class="newsletter-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 7l10 7 10-7"/>
          </svg>
        </div>
        <h3 class="newsletter-title">{t.newsletter.title}</h3>
        <p class="newsletter-subtitle">{t.newsletter.subtitle}</p>
      </div>
      <form class="newsletter-form" onsubmit="return false;">
        <input class="newsletter-input" type="email" placeholder={t.newsletter.placeholder} required />
        <button type="submit" class="newsletter-btn" aria-label="Suscribirse">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  type CartItem = {
    dessertId: string; nameEs: string; nameEn: string; price: number;
    quantity: number; imageUrl: string; slug: string; sizeEs?: string; sizeEn?: string;
  };
  document.querySelectorAll<HTMLButtonElement>('[data-add-to-cart]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const cart: CartItem[] = JSON.parse(localStorage.getItem('jj_cart') || '[]');
      const id = btn.dataset.id || '';
      const sizeEs = btn.dataset.sizeEs || '';
      const existing = cart.find((i) => i.dessertId === id && (i.sizeEs || '') === sizeEs);
      if (existing) { existing.quantity += 1; }
      else {
        cart.push({
          dessertId: id,
          nameEs: btn.dataset.nameEs || '',
          nameEn: btn.dataset.nameEn || '',
          price: parseFloat(btn.dataset.price || '0'),
          quantity: 1,
          imageUrl: btn.dataset.image || '',
          slug: btn.dataset.slug || '',
          sizeEs,
          sizeEn: btn.dataset.sizeEn || '',
        });
      }
      localStorage.setItem('jj_cart', JSON.stringify(cart));
      document.dispatchEvent(new Event('cart:updated'));
      btn.textContent = 'OK';
      setTimeout(() => { btn.textContent = 'Agregar'; }, 1200);
    });
  });
</script>
